# ============================================================
# EVERASTORE - Environment Variables
# Salin file ini jadi ".env" untuk lokal, ATAU isi nilai-nilai
# berikut di Vercel: Project Settings > Environment Variables.
# JANGAN commit file .env yang sudah berisi nilai asli ke GitHub.
# ============================================================

# --- Admin ---
# Password untuk login ke dashboard admin web kamu.
ADMIN_PASSWORD=ganti_dengan_password_kuat

# --- Firebase / Firestore ---
# Project ID Firebase kamu (lihat di Firebase Console > Project settings).
FIREBASE_PROJECT_ID=everast-27aec
# Web API Key Firebase (Project settings > General > Web API Key).
FIREBASE_API_KEY=AIzaSy...ganti_dengan_punyamu

# --- SakuRupiah (Payment Gateway) ---
SAKURUPIAH_MERCHANT_ID=isi_merchant_id
SAKURUPIAH_API_KEY=isi_api_key
# Metode pembayaran default (mis. QRIS). Sesuaikan dengan dokumentasi SakuRupiah.
SAKURUPIAH_PAYMENT_METHOD=QRIS

# --- MatchaShop (Provider Auto-Topup) ---  *** BARU ***
# Base URL API MatchaShop. CEK DI DASHBOARD MATCHASHOP (menu Integrasi/API).
# Jangan pakai garis miring di akhir. Contoh:
MATCHASHOP_BASE_URL=https://api.matchashop.id
# API Key dari dashboard MatchaShop > menu Integrasi.
MATCHASHOP_API_KEY=isi_api_key_matchashop

# --- Domain publik web kamu ---  *** BARU ***
# Dipakai untuk URL callback topup yang dikirim ke MatchaShop.
# Isi domain Vercel/custom domain kamu, tanpa garis miring di akhir.
PUBLIC_BASE_URL=https://evera-payment-gateway-tester.vercel.app
